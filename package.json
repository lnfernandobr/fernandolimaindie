{
  "name": "blog-network",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-channel automated blog network: API + Admin + Blog template",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @bn/api dev",
    "dev:admin": "pnpm --filter @bn/admin dev",
    "dev:sonoprofundo": "pnpm --filter @bn/sonoprofundo dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "seed": "pnpm --filter @bn/api seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\""
  },
  "devDependencies": {
    "prettier": "3.8.3",
    "typescript": "5.9.3"
  }
}
