# Produção — preencha com valores reais antes do deploy.
# Em desenvolvimento, use .env.local (que tem precedência sobre este arquivo).
NODE_ENV=production
API_PORT=4000

# String do MongoDB Atlas em produção
MONGODB_URI=

# >= 32 chars, único por ambiente
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Mesmo valor deve estar no blog (.env de produção do blog)
REVALIDATE_SECRET=

LOG_LEVEL=info

# Bootstrap do usuário admin (criado apenas uma vez se ainda não existe)
ADMIN_BOOTSTRAP_NAME=Fernando
ADMIN_BOOTSTRAP_USERNAME=fernando
ADMIN_BOOTSTRAP_PASSWORD=

# CORS — origins permitidos no admin/sites. Lista separada por vírgula. "*" = aberto.
# Em produção: https://admin.exemplo.com,https://meusite.com,https://social.exemplo.com
ALLOWED_ORIGINS=

# Camada de IA — provider de TEXTO.
# Combinação recomendada em prod: AI_PROVIDER=claude + IMAGE_PROVIDER=openai
AI_PROVIDER=mock
AI_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Provider de IMAGEM (independente do de texto).
IMAGE_PROVIDER=mock
IMAGE_MODEL=

# URL pública da API — usada pra montar URLs de imagens quando S3 não está habilitado.
# Em produção: https://api.SEUDOMINIO.com
PUBLIC_API_URL=

# ─── Storage S3 das imagens geradas (recomendado em prod) ──────────────────
# Se UPLOADS_S3_BUCKET for setado, imagens vão pra S3. Caso contrário, vão
# pro disco local (/uploads/) — útil em dev mas frágil em redeploy.
UPLOADS_S3_BUCKET=
UPLOADS_S3_REGION=us-east-1
# Default: https://<bucket>.s3.<region>.amazonaws.com
# Set se usar CloudFront/domínio custom: https://cdn.SEUDOMINIO.com
UPLOADS_PUBLIC_BASE_URL=
# Em VPS AWS com IAM role anexada, deixe em branco (SDK pega automático).
# Em dev/CI, use access keys com permissão s3:PutObject + s3:GetObject no bucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google PageSpeed Insights — gratuita, 25k req/dia.
# Pega em https://console.cloud.google.com/apis/credentials → Create credentials → API key.
GOOGLE_PAGESPEED_API_KEY=

# ─── TikTok Content Posting API ────────────────────────────────────────────
# Credenciais OAuth do app em https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Chave de verificação de domínio (file-based) — gerada no TikTok portal ao
# adicionar o domínio. Servida em GET /tiktok<KEY>.txt
TIKTOK_DOMAIN_VERIFICATION_KEY=

# Social admin URL — usado como destino de redirect após OAuth do TikTok
SOCIAL_ADMIN_URL=

# ─── Resend (notificações por email) ────────────────────────────────────────
# https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
