# Produção — preencha com valores reais antes do deploy.
# Em desenvolvimento, use .env.local (que tem precedência sobre este arquivo).
NODE_ENV=production
API_PORT=4000

# String do MongoDB Atlas em produção
MONGODB_URI=

# >= 32 chars, único por ambiente
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Mesmo valor deve estar no blog (.env de produção do blog)
REVALIDATE_SECRET=

LOG_LEVEL=info

# Bootstrap do usuário admin (criado apenas uma vez se ainda não existe)
ADMIN_BOOTSTRAP_NAME=Fernando
ADMIN_BOOTSTRAP_USERNAME=fernando
ADMIN_BOOTSTRAP_PASSWORD=

# A URL do site para revalidação ISR vem do próprio canal (siteUrl), não daqui.

# CORS — origins permitidos no admin/sites. Lista separada por vírgula. "*" = aberto.
# Em produção: https://admin.exemplo.com,https://meusite.com
ALLOWED_ORIGINS=

# Camada de IA — provider de TEXTO.
# Combinação recomendada em prod: AI_PROVIDER=claude (Sonnet 4.6) + IMAGE_PROVIDER=openai (gpt-image-1)
AI_PROVIDER=mock
AI_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Provider de IMAGEM (independente do de texto).
IMAGE_PROVIDER=mock
IMAGE_MODEL=

# URL pública da API — usada pra montar URLs de imagens em /uploads/.
# Em produção: https://api.SEUDOMINIO.com
PUBLIC_API_URL=

# Google PageSpeed Insights — gratuita, 25k req/dia.
# Pega em https://console.cloud.google.com/apis/credentials → Create credentials → API key.
# Restrinja a chave à API "PageSpeed Insights API" e a HTTP referrers se preferir.
GOOGLE_PAGESPEED_API_KEY=
