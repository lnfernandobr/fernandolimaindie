    "seed": "tsx src/seed/run.ts",
    "remove-channel": "tsx src/scripts/remove-channel.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.92.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@bn/shared": "workspace:*",
    "bcryptjs": "3.0.3",
    "cors": "2.8.6",
    "cron-parser": "5.5.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.6.1",
    "node-cron": "4.2.1",
    "openai": "6.35.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "tsx": "4.21.0",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.6.0",
    "typescript": "5.9.3"
